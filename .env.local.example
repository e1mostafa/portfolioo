# ============================================================
# ENVIRONMENT VARIABLES — Copy to .env.local and fill in values
# ============================================================

# Site URL (used for OG images and SEO)
NEXT_PUBLIC_SITE_URL=https://elmostafa.dev

# ——— Email (choose one) ———

# Option 1: Resend (recommended — https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=hello@elmostafa.dev

# Option 2: Formspree (no backend needed)
# Set the form action URL in Contact.tsx
# NEXT_PUBLIC_FORMSPREE_URL=https://formspree.io/f/xxxxxxxx

# Option 3: EmailJS (client-side)
# NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_xxxxxxx
# NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=template_xxxxxxx
# NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxx

# ——— Analytics (optional) ———
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=elmostafa.dev

# ——— Vercel (auto-set by Vercel, don't manually add) ———
# VERCEL_URL
# VERCEL_ENV
